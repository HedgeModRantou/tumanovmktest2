<?xml version="1.0" encoding="utf-8"?>
<!--
    Корневой контейнер — LinearLayout (вертикальный).
    Секции идут сверху вниз, каждая занимает свою долю экрана через layout_weight.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/screen_padding"
    tools:context=".LayoutDemoActivity">

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_layouts"
        android:textSize="@dimen/text_title"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- ══════════════════════════════════════════
         СЕКЦИЯ 1: LinearLayout (горизонтальный)
         Три кнопки делят пространство: 1/3, 1/3, 1/3
         ══════════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/lbl_linear"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="@color/card_bg"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <Button
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="1/3"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:onClick="onLinearClick"
            android:layout_marginEnd="4dp"/>

        <Button
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="1/3"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white"
            android:onClick="onLinearClick"
            android:layout_marginEnd="4dp"/>

        <Button
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="1/3"
            android:backgroundTint="@color/secondary"
            android:textColor="@color/white"
            android:onClick="onLinearClick"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         СЕКЦИЯ 2: RelativeLayout
         Надпись в левом верхнем, кнопка в правом нижнем
         ══════════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/lbl_relative"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/card_bg"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvLeftTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pos_left_top"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_label"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pos_right_bottom"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:onClick="onRelativeClick"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>

    </RelativeLayout>

    <!-- ══════════════════════════════════════════
         СЕКЦИЯ 3: FrameLayout
         Два элемента накладываются: фоновый текст и кнопка поверх
         ══════════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/lbl_frame"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/card_bg"
        android:layout_marginBottom="8dp">

        <!-- Фоновый элемент -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/frame_bg_text"
            android:textColor="@color/frame_bg_text_color"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"/>

        <!-- Элемент поверх (foreground) -->
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/frame_fg_btn"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:onClick="onFrameClick"
            android:layout_gravity="center"/>

    </FrameLayout>

    <!-- Кнопка "Назад" -->
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_back"
        android:onClick="onBackPressed"
        android:backgroundTint="@color/secondary"
        android:textColor="@color/white"
        android:textSize="@dimen/text_button"/>

</LinearLayout>
